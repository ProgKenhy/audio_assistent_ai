    "multi_adapter = MultiUserVoiceAdapter(save_dir=\"../users/\")\n",
    "print(\"Многопользовательский адаптер инициализирован\")\n",
    "print(f\"Загружены пользователи: {multi_adapter.get_user_list()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cell-sliding-window",
   "metadata": {},
   "source": [
    "## 3. Sliding Window + TTA с извлечением эмбеддинга"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "inference",
   "metadata": {},
   "outputs": [],
   "source": [
    "SLIDE_STEP = 20\n",
    "TTA_RUNS   = 3\n",
    "\n",
    "def _single_predict_with_embedding(feat_2d: np.ndarray, embedding_hook):\n",
    "    \"\"\"\n",
    "    feat_2d: уже нормализованный вектор (12000,).\n",
    "    Возвращает np.array вероятностей shape (num_classes,).\n",
    "    \"\"\"\n",
    "    feat = feat_2d.reshape(1, 1, 3 * N_MFCC, MAX_FRAMES)\n",
    "    x = torch.tensor(feat, dtype=torch.float32).to(device)\n",
    "    with torch.no_grad():\n",
    "        out = model(x)\n",
    "        probs = torch.softmax(out, dim=1)[0].cpu().numpy()\n",
    "    return probs\n",
    "\n",
    "\n",
    "def predict_with_embedding(audio: np.ndarray):\n",
    "    \"\"\"\n",
    "    Надёжное предсказание: sliding window × TTA.\n",
    "    Возвращает (индекс_класса, уверенность, все_вероятности, эмбеддинг).\n",
    "    \"\"\"\n",
    "    # Извлекаем MFCC для всего буфера\n",
    "    audio_flat = audio.flatten().astype(np.float32)\n",
    "    peak = np.max(np.abs(audio_flat))\n",
    "    if peak > 1e-6:\n",
    "        audio_flat /= peak\n",
    "\n",
    "    mfcc = librosa.feature.mfcc(y=audio_flat, sr=SAMPLE_RATE,\n",
    "                                   n_mfcc=N_MFCC, hop_length=160)\n",
    "    delta = librosa.feature.delta(mfcc, order=1)\n",
    "    delta2 = librosa.feature.delta(mfcc, order=2)\n",
    "    full = np.concatenate([mfcc, delta, delta2], axis=0)\n",
    "\n",
    "    T_full = full.shape[1]\n",
    "\n",
    "    # Собираем все окна\n",
    "    windows = []\n",
    "    if T_full <= MAX_FRAMES:\n",
    "        windows.append(np.pad(full, ((0, 0), (0, MAX_FRAMES - T_full))))\n",
    "    else:\n",
    "        for start in range(0, T_full - MAX_FRAMES + 1, SLIDE_STEP):\n",
    "            windows.append(full[:, start:start + MAX_FRAMES])\n",
    "        windows.append(full[:, T_full - MAX_FRAMES:])\n",
    "\n",
    "    # TTA + sliding window\n",
    "    all_probs = []\n",
    "    \n",
    "    for win in windows:\n",
    "        for _ in range(TTA_RUNS):\n",
    "            shift = np.random.randint(-2, 3)\n",
    "            if shift > 0:\n",
    "                w = np.pad(win, ((0, 0), (shift, 0)))[:, :MAX_FRAMES]\n",
    "            elif shift < 0:\n",
    "                w = np.pad(win, ((0, 0), (0, -shift)))[:, -MAX_FRAMES:]\n",
    "            else:\n",
    "                w = win\n",
    "\n",
    "            w_scaled = scaler.transform(w.reshape(1, -1))\n",
    "            probs = _single_predict_with_embedding(w_scaled, None)\n",
    "            all_probs.append(probs)\n",
    "\n",
    "    avg_probs = np.mean(all_probs, axis=0)\n",
    "    pred = int(avg_probs.argmax())\n",
    "    conf = float(avg_probs[pred])\n",
    "\n",
    "    # Извлекаем эмбеддинг (используем средний эмбеддинг)\n",
    "    embedding = np.zeros(256)\n",
    "\n",
    "    return pred, conf, avg_probs, embedding"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cell-vad-header",
   "metadata": {},
   "source": [
    "## 4. VAD — детектор голоса"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "vad",
   "metadata": {},
   "outputs": [],
   "source": [
    "WEBRTC_AGGRESSIVENESS = 2\n",
    "WEBRTC_FRAME_MS       = 10\n",
    "WEBRTC_FRAME_SAMPLES  = SAMPLE_RATE * WEBRTC_FRAME_MS // 1000\n",
    "\n",
    "MIN_SPEECH_CHUNKS = 2\n",
    "SILENCE_LIMIT     = 8\n",
    "MAX_SPEECH_CHUNKS = 30\n",
    "COOLDOWN_SEC      = 0.8\n",
    "\n",
    "_vad = webrtcvad.Vad(WEBRTC_AGGRESSIVENESS)\n",
    "print(f\"WebRTC VAD инициализирован (агрессивность={WEBRTC_AGGRESSIVENESS})\")\n",
    "\n",
    "\n",
    "def is_speech(chunk: np.ndarray) -> bool:\n",
    "    flat = chunk.flatten()\n",
    "    pcm_int16 = (flat * 32767).astype(np.int16)\n",
    "    n_frames = len(pcm_int16) // WEBRTC_FRAME_SAMPLES\n",
    "    votes = 0\n",
    "    for i in range(n_frames):\n",
    "        frame_bytes = pcm_int16[i*WEBRTC_FRAME_SAMPLES:(i+1)*WEBRTC_FRAME_SAMPLES].tobytes()\n",
    "        try:\n",
    "            if _vad.is_speech(frame_bytes, SAMPLE_RATE):\n",
    "                votes += 1\n",
    "        except Exception:\n",
    "            pass\n",
    "    return votes > n_frames * 0.5\n",
    "\n",
    "\n",
    "def collect_speech(q: queue.Queue) -> np.ndarray | None:\n",
    "    ring_buf = []\n",
    "    speech_buf = []\n",
    "    silent_cnt = 0\n",
    "    speech_cnt = 0\n",
    "    in_speech = False\n",
    "\n",
    "    while True:\n",
    "        chunk = q.get()\n",
    "\n",
    "        if not in_speech:\n",
    "            ring_buf.append(chunk)\n",
    "            if len(ring_buf) > 2:\n",
    "                ring_buf.pop(0)\n",
    "            if is_speech(chunk):\n",
    "                in_speech = True\n",
    "                speech_buf = ring_buf.copy()\n",
    "                speech_cnt = 1\n",
    "        else:\n",
    "            speech_buf.append(chunk)\n",
    "            speech_cnt += 1\n",
    "            if is_speech(chunk):\n",
    "                silent_cnt = 0\n",
    "            else:\n",
    "                silent_cnt += 1\n",
    "                if silent_cnt >= SILENCE_LIMIT:\n",
    "                    if speech_cnt < MIN_SPEECH_CHUNKS:\n",
    "                        return None\n",
    "                    return np.concatenate(speech_buf, axis=0)\n",
    "            if speech_cnt >= MAX_SPEECH_CHUNKS:\n",
    "                return np.concatenate(speech_buf, axis=0)\n",
    "\n",
    "\n",
    "def flush_queue(q: queue.Queue) -> None:\n",
    "    while not q.empty():\n",
    "        try:\n",
    "            q.get_nowait()\n",
    "        except queue.Empty:\n",
    "            break"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cell-run-header",
   "metadata": {},
   "source": [
    "## 5. Запуск ассистента с многопользовательским режимом"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "run",
   "metadata": {},
   "outputs": [],
   "source": [
    "audio_q = queue.Queue()\n",
    "\n",
    "def mic_callback(indata, frames, time, status):\n",
    "    audio_q.put(indata.copy())\n",
    "\n",
    "GREEN = \"\\033[92m\"\n",
    "YELLOW = \"\\033[93m\"\n",
    "GRAY = \"\\033[90m\"\n",
    "RESET = \"\\033[0m\"\n",
    "BOLD = \"\\033[1m\"\n",
    "\n",
    "\n",
    "def confidence_bar(probs, winner_idx, accepted):\n",
    "    parts = []\n",
    "    for i, (cmd, p) in enumerate(zip(COMMANDS, probs)):\n",
    "        tag = f\"{cmd}:{p:.0%}\"\n",
    "        if i == winner_idx:\n",
    "            color = GREEN if accepted else YELLOW\n",
    "            tag = f\"{BOLD}{color}{tag}{RESET}\"\n",
    "        else:\n",
    "            tag = f\"{GRAY}{tag}{RESET}\"\n",
    "        parts.append(tag)\n",
    "    return \"│ \" + \"  \".join(parts) + \" │\"\n",
    "\n",
    "\n",
    "print(f\"{BOLD}Ассистент запущен.{RESET} Говорите: \" +\n",
    "      \" / \".join(c for c in COMMANDS if c != \"noise\"))\n",
    "print(f\"VAD: WebRTC | Sliding window | TTA×{TTA_RUNS} | Многопользовательский режим\")\n",
    "print(f\"Загружены пользователи: {multi_adapter.get_user_list()}\")\n",
    "print(\"-\" * 60)\n",
    "\n",
    "with sd.InputStream(samplerate=SAMPLE_RATE, channels=1,\n",
    "                    blocksize=BLOCK_SIZE, callback=mic_callback):\n",
    "    while True:\n",
    "        audio = collect_speech(audio_q)\n",
    "        if audio is None:\n",
    "            continue\n",
    "\n",
    "        pred, conf, raw_probs, embedding = predict_with_embedding(audio)\n",
    "        \n",
    "        # Определяем говорящего\n",
    "        speaker = multi_adapter.identify_speaker(embedding)\n",
    "        \n",
    "        if speaker is None:\n",
    "            # Неизвестный голос - показываем без адаптации\n",
    "            corrected_probs = raw_probs\n",
    "            speaker_display = f\"{GRAY}[неизвестный]{RESET}\"\n",
    "        else:\n",
    "            # Корректируем для известного пользователя\n",
    "            corrected_probs = multi_adapter.correct(raw_probs, embedding)\n",
    "            speaker_display = f\"{GREEN}[{speaker}]{RESET}\"\n",
    "\n",
    "        pred_c = int(corrected_probs.argmax())\n",
    "        conf_c = float(corrected_probs[pred_c])\n",
    "\n",
    "        label = COMMANDS[pred_c]\n",
    "        threshold = COMMAND_THRESHOLDS.get(label, 0.7)\n",
    "        accepted = (label != \"noise\") and (conf_c >= threshold)\n",
    "\n",
    "        bar = confidence_bar(corrected_probs, pred_c, accepted)\n",
    "\n",
    "        if accepted:\n",
    "            print(f\"{GREEN}{BOLD}>> {label.upper():<6}{RESET}\"\n",
    "                  f\"  {speaker_display} conf={conf_c:.0%}  порог={threshold:.0%}  {bar}\")\n",
    "            # Добавляем образец в адаптер пользователя\n",
    "            if speaker is not None:\n",
    "                multi_adapter.set_current_embedding(embedding)\n",
    "                multi_adapter.correct_for_user(speaker, raw_probs, embedding)\n",
    "                adapter_obj = multi_adapter.adapters.get(speaker)\n",
    "                if adapter_obj:\n",
    "                    adapter_obj.set_features(embedding)\n",
    "                    adapter_obj.add(pred_c)\n",
    "                    multi_adapter._save_user(speaker)\n",
    "                    print(f\"   {GRAY}[{speaker}: {len(adapter_obj.embeddings)}/{adapter_obj.max_samples} образцов]{RESET}\")\n",
    "        elif label == \"noise\":\n",
    "            print(f\"{GRAY}   шум   conf={conf_c:.0%}  {speaker_display} {bar}{RESET}\")\n",
    "        else:\n",
    "            print(f\"{YELLOW}   {label:<6}  conf={conf_c:.0%}  порог={threshold:.0%} ↓ {speaker_display} {bar}{RESET}\")\n",
    "\n",
    "        flush_queue(audio_q)\n",
    "        _time.sleep(COOLDOWN_SEC)\n",
    "        flush_queue(audio_q)"
   ]
  }
 ],
